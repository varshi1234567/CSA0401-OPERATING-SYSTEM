#include <stdio.h>
#include <unistd.h>

int main()
{
    pid_t pid;

    pid = fork();

    if(pid == 0)
    {
        printf("\nChild Process");
        printf("\nChild PID = %d", getpid());
        printf("\nParent PID = %d\n", getppid());
    }
    else if(pid > 0)
    {
        printf("\nParent Process");
        printf("\nParent PID = %d", getpid());
        printf("\nParent's Parent PID = %d\n", getppid());
    }
    else
    {
        printf("Fork failed");
    }

    return 0;
}
